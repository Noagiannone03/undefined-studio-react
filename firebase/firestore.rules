rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == "kVurSY6zZMYaDI2xZJ3a4JydJFG2";
    }

    function isOwnUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasUserDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function canAccessClient(clientId) {
      return isAdmin()
        || (
          signedIn()
          && hasUserDoc()
          && clientId is string
          && clientId in myUser().clientIds
        );
    }

    match /users/{uid} {
      allow read: if isOwnUser(uid) || isAdmin();

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (
          isOwnUser(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['name', 'email', 'mustChangePassword', 'updatedAt'])
        );

      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if canAccessClient(clientId);
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if canAccessClient(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /projectUpdates/{updateId} {
      allow read: if canAccessClient(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if canAccessClient(resource.data.clientId);
      allow write: if isAdmin();
    }

    match /invoiceProducts/{productId} {
      allow read, write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if canAccessClient(resource.data.clientId);

      allow create: if signedIn()
        && hasUserDoc()
        && request.resource.data.clientId is string
        && request.resource.data.clientId in myUser().clientIds
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == "open";

      allow update: if isAdmin()
        || (signedIn()
          && hasUserDoc()
          && resource.data.clientId is string
          && resource.data.clientId in myUser().clientIds
          && request.resource.data.clientId == resource.data.clientId);

      allow delete: if isAdmin();
    }
  }
}
